{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SGAF",
  "version": "0.1.0",
  "identifier": "com.sgaf.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SGAF - Sistema de Gestión de Activos Fijos",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "visible": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/sgaf-backend"
    ]
  }
}
